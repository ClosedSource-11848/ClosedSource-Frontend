@startuml shared-frontend-diagram
title QualiTrack – Shared Frontend

package "shared" {

  package "domain" {

    interface ApiResponse {
      +data: T
      +message: string
      +status: number
    }

    interface PagedResult {
      +items: T[]
      +totalItems: number
      +page: number
      +pageSize: number
    }

    interface DateRange {
      +from: Date
      +to: Date
    }

    interface ErrorDetail {
      +field: string
      +message: string
      +code: string
    }

    interface ErrorResponse {
      +status: number
      +message: string
      +errors: ErrorDetail[]
      +timestamp: Date
      +path: string
    }
  }

  package "application" {

    class ToastService {
      +showSuccess(message: string): void
      +showError(message: string): void
      +showWarning(message: string): void
      +showInfo(message: string): void
      +clear(): void
    }

    class AuthFacadeRef {
      +isAuthenticated(): boolean
      +getToken(): string
      +getCurrentUserId(): string
      +getCurrentRole(): string
      +logout(): void
    }
  }

  package "infrastructure" {

    class BaseHttpService {
      -http: HttpClient
      -baseUrl: string
      +get<T>(endpoint: string, params?: any): Observable<T>
      +post<T>(endpoint: string, body: any): Observable<T>
      +put<T>(endpoint: string, body: any): Observable<T>
      +patch<T>(endpoint: string, body: any): Observable<T>
      +delete<T>(endpoint: string): Observable<T>
      +downloadBlob(endpoint: string, params?: any): Observable<Blob>
      +buildParams(params: any): HttpParams
    }

    class TokenInterceptor {
      -authFacadeRef: AuthFacadeRef
      +intercept(req: HttpRequest<any>, next: HttpHandler): Observable<HttpEvent<any>>
      -addAuthorizationHeader(req: HttpRequest<any>, token: string): HttpRequest<any>
    }

    class ErrorInterceptor {
      -authFacadeRef: AuthFacadeRef
      -toastService: ToastService
      -router: Router
      +intercept(req: HttpRequest<any>, next: HttpHandler): Observable<HttpEvent<any>>
      -handleUnauthorized(): void
      -handleForbidden(): void
      -handleServerError(error: HttpErrorResponse): void
    }
  }

  package "interfaces" {

    class AuthGuard {
      -authFacadeRef: AuthFacadeRef
      -router: Router
      +canActivate(route: ActivatedRouteSnapshot): boolean
      -redirectToLogin(): void
    }

    class RoleGuard {
      -authFacadeRef: AuthFacadeRef
      -router: Router
      +requiredRoles: string[]
      +canActivate(route: ActivatedRouteSnapshot): boolean
    }

    class ConfirmDialogComponent {
      +title: string
      +message: string
      +confirmLabel: string
      +cancelLabel: string
      +isDanger: boolean
      +confirmed: EventEmitter<void>
      +cancelled: EventEmitter<void>
      +onConfirm(): void
      +onCancel(): void
    }

    class StatusBadgeComponent {
      +status: string
      +statusColorMap: Map<string, string>
      +statusLabelMap: Map<string, string>
      +getColor(): string
      +getLabel(): string
    }

    class DateRangePickerComponent {
      +range: DateRange
      +rangeChange: EventEmitter<DateRange>
      +minDate: Date
      +maxDate: Date
      +onFromChange(date: Date): void
      +onToChange(date: Date): void
      +isValidRange(): boolean
    }

    class SearchInputComponent {
      +placeholder: string
      +searchTerm: string
      +debounceMs: number
      +searchChange: EventEmitter<string>
      +ngOnInit(): void
      +onInput(value: string): void
      +onClear(): void
    }

    class LoadingSpinnerComponent {
      +isLoading: boolean
      +message: string
      +fullScreen: boolean
    }

    class PaginatorComponent {
      +totalItems: number
      +pageSize: number
      +currentPage: number
      +pageSizeOptions: number[]
      +pageChange: EventEmitter<number>
      +pageSizeChange: EventEmitter<number>
      +getTotalPages(): number
      +onPageChange(page: number): void
    }

    class EmptyStateComponent {
      +title: string
      +message: string
      +actionLabel: string
      +iconName: string
      +action: EventEmitter<void>
      +onAction(): void
    }

    class FormatDatePipe {
      +transform(date: Date, format: string): string
    }

    class TruncatePipe {
      +transform(value: string, maxLength: number): string
    }

    class CapitalizePipe {
      +transform(value: string): string
    }
  }
}

BaseHttpService --> TokenInterceptor
BaseHttpService --> ErrorInterceptor
BaseHttpService ..> ApiResponse
BaseHttpService ..> PagedResult

TokenInterceptor --> AuthFacadeRef
ErrorInterceptor --> AuthFacadeRef
ErrorInterceptor --> ToastService

AuthGuard --> AuthFacadeRef
RoleGuard --> AuthFacadeRef

DateRangePickerComponent ..> DateRange
ErrorInterceptor ..> ErrorResponse

@enduml
