@startuml equipment-frontend-diagram
title QualiTrack – Equipment Management Frontend

package "equipment-management" {

  package "domain" {

    interface Equipment {
      +id: string
      +labId: string
      +name: string
      +type: EquipmentType
      +deviceId: string
      +status: EquipmentStatus
      +lastCalibrationDate: Date
      +nextCalibrationDate: Date
      +bpmConfig: BpmParameterConfig[]
    }

    interface BpmParameterConfig {
      +equipmentId: string
      +variable: CriticalVariable
      +minValue: number
      +maxValue: number
      +unit: string
    }

    interface MaintenanceRecord {
      +id: string
      +equipmentId: string
      +maintenanceType: MaintenanceType
      +date: Date
      +technician: string
      +observations: string
    }

    interface CalibrationAlert {
      +equipmentId: string
      +equipmentName: string
      +daysUntilExpiry: number
      +nextCalibrationDate: Date
      +isCritical: boolean
    }

    interface RegisterEquipmentCommand {
      +labId: string
      +name: string
      +type: EquipmentType
      +deviceId: string
    }

    interface LinkSensorCommand {
      +labId: string
      +equipmentId: string
      +deviceId: string
    }

    interface ConfigureBpmCommand {
      +equipmentId: string
      +parameters: BpmParameterConfig[]
    }

    interface RegisterMaintenanceCommand {
      +equipmentId: string
      +maintenanceType: MaintenanceType
      +date: Date
      +technician: string
      +observations: string
    }

    enum EquipmentType {
      AUTOCLAVE
      PH_METER
      THERMOMETER
      PRESSURE_SENSOR
      CENTRIFUGE
      SPECTROPHOTOMETER
    }

    enum EquipmentStatus {
      ACTIVE
      INACTIVE
      UNDER_MAINTENANCE
      PENDING_CALIBRATION
    }

    enum CriticalVariable {
      TEMPERATURE
      PRESSURE
      PH
      HUMIDITY
      FLOW_RATE
    }

    enum MaintenanceType {
      PREVENTIVE
      CORRECTIVE
      CALIBRATION
    }
  }

  package "application" {

    class EquipmentFacade {
      -equipmentApiService: EquipmentApiService
      +getEquipment(labId: string): Observable<Equipment[]>
      +getEquipmentById(labId: string, equipmentId: string): Observable<Equipment>
      +registerEquipment(command: RegisterEquipmentCommand): Observable<Equipment>
      +linkSensor(command: LinkSensorCommand): Observable<void>
      +configureBpmParameters(command: ConfigureBpmCommand): Observable<void>
      +getMaintenanceHistory(equipmentId: string): Observable<MaintenanceRecord[]>
      +registerMaintenance(command: RegisterMaintenanceCommand): Observable<MaintenanceRecord>
      +getCalibrationAlerts(labId: string): Observable<CalibrationAlert[]>
    }
  }

  package "infrastructure" {

    class EquipmentApiService {
      -http: HttpClient
      -baseUrl: string
      +getEquipment(labId: string): Observable<Equipment[]>
      +getEquipmentById(labId: string, equipmentId: string): Observable<Equipment>
      +registerEquipment(labId: string, body: RegisterEquipmentCommand): Observable<Equipment>
      +linkSensor(labId: string, equipmentId: string, body: LinkSensorCommand): Observable<void>
      +configureBpm(equipmentId: string, body: ConfigureBpmCommand): Observable<void>
      +getMaintenanceHistory(equipmentId: string): Observable<MaintenanceRecord[]>
      +registerMaintenance(equipmentId: string, body: RegisterMaintenanceCommand): Observable<MaintenanceRecord>
      +getCalibrationAlerts(labId: string): Observable<CalibrationAlert[]>
    }
  }

  package "interfaces" {

    class EquipmentListComponent {
      -equipmentFacade: EquipmentFacade
      +equipmentList: Equipment[]
      +isLoading: boolean
      +searchTerm: string
      +ngOnInit(): void
      +loadEquipment(): void
      +onSearch(): void
      +onViewDetail(equipmentId: string): void
    }

    class EquipmentDetailComponent {
      -equipmentFacade: EquipmentFacade
      +equipment: Equipment
      +maintenanceHistory: MaintenanceRecord[]
      +isLoading: boolean
      +activeTab: string
      +ngOnInit(): void
      +loadDetail(): void
      +getStatusColor(): string
    }

    class EquipmentFormComponent {
      -equipmentFacade: EquipmentFacade
      -toastService: ToastService
      +form: FormGroup
      +equipmentTypes: EquipmentType[]
      +isLoading: boolean
      +isEditMode: boolean
      +ngOnInit(): void
      +buildForm(): void
      +onSubmit(): void
    }

    class BpmConfigFormComponent {
      -equipmentFacade: EquipmentFacade
      -toastService: ToastService
      +equipmentId: string
      +bpmParameters: BpmParameterConfig[]
      +form: FormGroup
      +variables: CriticalVariable[]
      +isLoading: boolean
      +ngOnInit(): void
      +addParameter(): void
      +removeParameter(index: number): void
      +onSave(): void
    }

    class MaintenanceHistoryComponent {
      -equipmentFacade: EquipmentFacade
      +equipmentId: string
      +maintenanceRecords: MaintenanceRecord[]
      +isLoading: boolean
      +ngOnInit(): void
      +loadHistory(): void
    }

    class MaintenanceFormComponent {
      -equipmentFacade: EquipmentFacade
      -toastService: ToastService
      +equipmentId: string
      +form: FormGroup
      +maintenanceTypes: MaintenanceType[]
      +isLoading: boolean
      +buildForm(): void
      +onSubmit(): void
    }

    class CalibrationAlertComponent {
      -equipmentFacade: EquipmentFacade
      +calibrationAlerts: CalibrationAlert[]
      +criticalAlerts: CalibrationAlert[]
      +isLoading: boolean
      +labId: string
      +ngOnInit(): void
      +loadAlerts(): void
      +isCritical(alert: CalibrationAlert): boolean
    }
  }
}

EquipmentFacade --> EquipmentApiService
EquipmentFacade ..> Equipment
EquipmentFacade ..> BpmParameterConfig
EquipmentFacade ..> MaintenanceRecord
EquipmentFacade ..> CalibrationAlert
EquipmentFacade ..> RegisterEquipmentCommand
EquipmentFacade ..> LinkSensorCommand
EquipmentFacade ..> ConfigureBpmCommand
EquipmentFacade ..> RegisterMaintenanceCommand

EquipmentListComponent --> EquipmentFacade
EquipmentDetailComponent --> EquipmentFacade
EquipmentDetailComponent --> MaintenanceHistoryComponent
EquipmentDetailComponent --> BpmConfigFormComponent
EquipmentFormComponent --> EquipmentFacade
BpmConfigFormComponent --> EquipmentFacade
MaintenanceHistoryComponent --> EquipmentFacade
MaintenanceFormComponent --> EquipmentFacade
CalibrationAlertComponent --> EquipmentFacade

@enduml
